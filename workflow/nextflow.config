// Use -profile slurm for HPC/SLURM execution.
// Omit -profile for local runs (e.g. smoke test with test.nf).

profiles {

    slurm {

        executor {
            name = 'slurm'
        }

        process {
            withName: 'RUN_BATCH' {
                memory = '160 GB'
                time   = '8h'
                // Adjust module names and TMPDIR for your cluster.
                beforeScript = '''
                    source /etc/profile.d/modules.sh
                    module purge
                    module load R/4.3.2
                    export TMPDIR="<PATH_TO_TMP_DIR>"
                '''
            }
            withName: 'SNP_BATCHES' {
                memory = '2 GB'
                time   = '10m'
            }
        }
    }
}
